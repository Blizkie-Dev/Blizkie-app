PORT=3000
NODE_ENV=development

# JWT - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# AES-256 encryption key for messages (32 bytes = 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-this

# Email (nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Blizkie <your@gmail.com>

# In dev mode, OTP codes are logged to console instead of sent
# Set to "true" to skip actual email/SMS sending
DEV_MODE=true
